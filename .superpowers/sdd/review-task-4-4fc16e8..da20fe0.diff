+    static func from(coverage: ProcessCoverage, hasCPU: Bool) -> Self {
+        guard coverage.enumerated > 0 else { return .unavailable }
+        guard hasCPU else { return .warmingUp }
+        return coverage.fraction < 0.90 ? .partial : .live
+    }
+}
