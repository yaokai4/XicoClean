+private actor FixtureProcessSnapshotProvider: ProcessSnapshotProviding {
+    private let captures: [ProcessCapture]
+    private var index = 0
+
+    init(captures: [ProcessCapture]) {
+        self.captures = captures
+    }
+
+    func capture() async -> ProcessCapture {
